# =============================================================================
# PM Agent 后端环境变量模板
# =============================================================================
# 使用方法：复制此文件为 .env，填入你的真实 API Key
#   cp .env.example .env
# =============================================================================

# ----- LLM Provider -----
# DeepSeek API 密钥（必需）
# 获取地址：https://platform.deepseek.com/api_keys
DEEPSEEK_API_KEY=sk-your-deepseek-api-key-here

# DeepSeek API 地址（可选，默认值已填写）
DEEPSEEK_BASE_URL=https://api.deepseek.com

# DeepSeek 模型名称（可选，默认 deepseek-chat）
DEEPSEEK_MODEL=deepseek-chat

# ----- Search Provider -----
# Tavily Search API 密钥（必需）
# 获取地址：https://app.tavily.com/home
TAVILY_API_KEY=tvly-your-tavily-api-key-here

# ----- Web 服务（Phase 2 启用） -----
# FastAPI 端口号（可选，默认 8000）
FASTAPI_PORT=8000
